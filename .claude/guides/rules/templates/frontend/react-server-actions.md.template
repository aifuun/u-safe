# React Server Actions Rules

> Next.js 14+ Server Actions. Server-side mutations with progressive enhancement and type safety.

## Quick Check

### Server Action Definition
- [ ] Has `'use server'` directive (file-level or function-level)
- [ ] Is async function
- [ ] Accepts serializable arguments only
- [ ] Returns serializable data
- [ ] Handles errors with try/catch

### Form Integration
- [ ] Passed to form `action` prop
- [ ] Receives `FormData` as argument
- [ ] Validates input data
- [ ] Revalidates cache after mutation
- [ ] Returns result for optimistic updates

### Security
- [ ] Validates all inputs
- [ ] Checks authentication/authorization
- [ ] Uses Zod/schema validation
- [ ] Sanitizes user data
- [ ] Rate limits sensitive operations

### Best Practices
- [ ] Colocated with relevant components
- [ ] Named with action suffix: `createUserAction`
- [ ] Revalidates affected paths/tags
- [ ] Returns type-safe results
- [ ] Handles both success and error cases

## Core Patterns

### 1. Basic Server Action (File-Level)

```typescript
// app/actions/users.ts
'use server'; // ✅ File-level directive - all exports are server actions

import { revalidatePath } from 'next/cache';
import { z } from 'zod';

const CreateUserSchema = z.object({
  name: z.string().min(1).max(100),
  email: z.string().email(),
});

export async function createUserAction(formData: FormData) {
  try {
    // ✅ Extract and validate data
    const validatedData = CreateUserSchema.parse({
      name: formData.get('name'),
      email: formData.get('email'),
    });

    // ✅ Perform mutation
    const user = await createUser(validatedData);

    // ✅ Revalidate affected paths
    revalidatePath('/users');

    return { success: true, user };
  } catch (error) {
    if (error instanceof z.ZodError) {
      return { success: false, error: error.errors };
    }
    return { success: false, error: 'Failed to create user' };
  }
}
```

### 2. Function-Level Server Action

```typescript
// app/components/UserForm.tsx
import { revalidatePath } from 'next/cache';

export function UserForm() {
  // ✅ Function-level directive
  async function handleSubmit(formData: FormData) {
    'use server';

    const name = formData.get('name');
    const user = await createUser({ name });

    revalidatePath('/users');
  }

  return (
    <form action={handleSubmit}>
      <input name="name" required />
      <button type="submit">Create User</button>
    </form>
  );
}
```

### 3. Form with Server Action

```typescript
// app/components/CreateUserForm.tsx
'use client';

import { useFormStatus, useFormState } from 'react-dom';
import { createUserAction } from '@/app/actions/users';

export function CreateUserForm() {
  const [state, formAction] = useFormState(createUserAction, null);

  return (
    <form action={formAction}>
      <div>
        <label htmlFor="name">Name</label>
        <input id="name" name="name" required />
      </div>

      <div>
        <label htmlFor="email">Email</label>
        <input id="email" name="email" type="email" required />
      </div>

      {state?.success === false && (
        <div className="error">{state.error}</div>
      )}

      <SubmitButton />
    </form>
  );
}

// ✅ Show loading state
function SubmitButton() {
  const { pending } = useFormStatus();

  return (
    <button type="submit" disabled={pending}>
      {pending ? 'Creating...' : 'Create User'}
    </button>
  );
}
```

### 4. Server Action with Arguments

```typescript
// app/actions/users.ts
'use server';

import { revalidatePath } from 'next/cache';

// ✅ Accept typed arguments (not FormData)
export async function deleteUserAction(userId: string) {
  try {
    await deleteUser(userId);

    revalidatePath('/users');

    return { success: true };
  } catch (error) {
    return { success: false, error: 'Failed to delete user' };
  }
}

// Client component
'use client';

export function DeleteButton({ userId }: { userId: string }) {
  return (
    <form action={() => deleteUserAction(userId)}>
      <button type="submit">Delete</button>
    </form>
  );
}
```

### 5. Optimistic Updates

```typescript
// app/components/TodoList.tsx
'use client';

import { useOptimistic } from 'react';
import { toggleTodoAction } from '@/app/actions/todos';

export function TodoList({ todos }: { todos: Todo[] }) {
  const [optimisticTodos, addOptimisticTodo] = useOptimistic(
    todos,
    (state, newTodo: Todo) => [...state, newTodo]
  );

  async function handleSubmit(formData: FormData) {
    const title = formData.get('title') as string;

    // ✅ Optimistically add todo
    addOptimisticTodo({ id: Date.now(), title, completed: false });

    // ✅ Then perform server action
    await createTodoAction(formData);
  }

  return (
    <div>
      <ul>
        {optimisticTodos.map((todo) => (
          <li key={todo.id}>{todo.title}</li>
        ))}
      </ul>

      <form action={handleSubmit}>
        <input name="title" required />
        <button type="submit">Add Todo</button>
      </form>
    </div>
  );
}
```

### 6. Revalidation Strategies

```typescript
// app/actions/posts.ts
'use server';

import { revalidatePath, revalidateTag } from 'next/cache';
import { redirect } from 'next/navigation';

// ✅ Revalidate specific path
export async function createPostAction(formData: FormData) {
  const post = await createPost({
    title: formData.get('title') as string,
  });

  revalidatePath('/posts'); // Revalidate posts list
  redirect(`/posts/${post.id}`); // Navigate to new post
}

// ✅ Revalidate by tag
export async function updatePostAction(postId: string, data: any) {
  await updatePost(postId, data);

  revalidateTag(`post-${postId}`); // Revalidate all caches tagged with this post
  revalidatePath(`/posts/${postId}`);
}

// ✅ Revalidate multiple paths
export async function publishPostAction(postId: string) {
  await publishPost(postId);

  revalidatePath('/posts'); // Revalidate list
  revalidatePath(`/posts/${postId}`); // Revalidate detail
  revalidatePath('/'); // Revalidate homepage
}
```

### 7. Authentication Check

```typescript
// app/actions/protected.ts
'use server';

import { cookies } from 'next/headers';
import { redirect } from 'next/navigation';

async function getUser() {
  const session = cookies().get('session')?.value;
  if (!session) return null;
  return await verifySession(session);
}

export async function deleteAccountAction() {
  // ✅ Check authentication
  const user = await getUser();

  if (!user) {
    redirect('/login');
  }

  // ✅ Perform authenticated action
  await deleteAccount(user.id);

  cookies().delete('session');
  redirect('/');
}
```

### 8. Error Handling

```typescript
// app/actions/users.ts
'use server';

import { z } from 'zod';

const UpdateUserSchema = z.object({
  name: z.string().min(1),
  email: z.string().email(),
});

type ActionResult =
  | { success: true; user: User }
  | { success: false; error: string; fieldErrors?: Record<string, string[]> };

export async function updateUserAction(
  userId: string,
  formData: FormData
): Promise<ActionResult> {
  try {
    // ✅ Validate input
    const validatedData = UpdateUserSchema.parse({
      name: formData.get('name'),
      email: formData.get('email'),
    });

    // ✅ Perform update
    const user = await updateUser(userId, validatedData);

    revalidatePath(`/users/${userId}`);

    return { success: true, user };
  } catch (error) {
    // ✅ Handle validation errors
    if (error instanceof z.ZodError) {
      return {
        success: false,
        error: 'Validation failed',
        fieldErrors: error.flatten().fieldErrors,
      };
    }

    // ✅ Handle other errors
    console.error('Error updating user:', error);
    return {
      success: false,
      error: 'Failed to update user',
    };
  }
}
```

## Anti-Patterns

### ❌ Using Client-Only APIs

```typescript
// ❌ BAD - Cannot use browser APIs in server actions
'use server';

export async function saveDataAction(formData: FormData) {
  const data = localStorage.getItem('data'); // ERROR! No localStorage on server
  await saveData(data);
}

// ✅ GOOD - Pass client data as argument
'use server';

export async function saveDataAction(data: string) {
  await saveData(data);
}

// Client
'use client';
export function SaveButton() {
  const handleClick = async () => {
    const data = localStorage.getItem('data');
    await saveDataAction(data);
  };
  return <button onClick={handleClick}>Save</button>;
}
```

### ❌ Not Validating Input

```typescript
// ❌ BAD - No validation
'use server';

export async function createUserAction(formData: FormData) {
  const user = await createUser({
    name: formData.get('name'), // Unsafe!
    email: formData.get('email'), // Unsafe!
  });
  return user;
}

// ✅ GOOD - Validate with schema
'use server';

export async function createUserAction(formData: FormData) {
  const validatedData = CreateUserSchema.parse({
    name: formData.get('name'),
    email: formData.get('email'),
  });

  const user = await createUser(validatedData);
  return user;
}
```

### ❌ Returning Non-Serializable Data

```typescript
// ❌ BAD - Cannot return functions or class instances
'use server';

export async function getUserAction() {
  return {
    user: { name: 'John' },
    greet: () => console.log('Hi'), // ERROR! Functions not serializable
    createdAt: new Date(), // ERROR! Dates not serializable
  };
}

// ✅ GOOD - Return plain objects and primitives
'use server';

export async function getUserAction() {
  return {
    user: { name: 'John' },
    createdAt: new Date().toISOString(), // Serialize date to string
  };
}
```

### ❌ Not Revalidating After Mutation

```typescript
// ❌ BAD - Data won't update in UI
'use server';

export async function createPostAction(formData: FormData) {
  const post = await createPost({
    title: formData.get('title'),
  });
  return post; // UI won't see new post!
}

// ✅ GOOD - Revalidate affected paths
'use server';

export async function createPostAction(formData: FormData) {
  const post = await createPost({
    title: formData.get('title'),
  });

  revalidatePath('/posts'); // ✅ Refresh posts list
  return post;
}
```

## Progressive Enhancement

```typescript
// ✅ Works without JavaScript
export function CreatePostForm() {
  return (
    <form action={createPostAction}>
      <input name="title" required />
      <button type="submit">Create Post</button>
    </form>
  );
}

// ✅ Enhanced with JavaScript (loading state, optimistic UI)
'use client';

export function CreatePostFormEnhanced() {
  const [state, formAction] = useFormState(createPostAction, null);
  const { pending } = useFormStatus();

  return (
    <form action={formAction}>
      <input name="title" required />
      <button type="submit" disabled={pending}>
        {pending ? 'Creating...' : 'Create Post'}
      </button>
      {state?.error && <div className="error">{state.error}</div>}
    </form>
  );
}
```

## Comparison: Server Actions vs API Routes

| Feature | Server Actions | API Routes |
|---------|---------------|------------|
| **Use Case** | Form submissions, mutations | Public APIs, external integrations |
| **Location** | Inline or dedicated files | `app/api/*/route.ts` |
| **Client Integration** | `<form action={action}>` | `fetch('/api/...')` |
| **Type Safety** | Full TypeScript end-to-end | Manual typing |
| **Progressive Enhancement** | ✅ Works without JS | ❌ Requires JS |
| **Request/Response** | Automatic serialization | Manual Response handling |
| **Authentication** | Check in function | Check in function |
| **CORS** | Not needed (same origin) | Configure headers |

**When to use Server Actions:**
- Form submissions
- Data mutations from React components
- Progressive enhancement desired
- Type safety end-to-end
- Internal operations only

**When to use API Routes:**
- Public/external APIs
- Webhooks
- Custom response headers/formats
- Non-form interactions
- Third-party integrations

## Testing

```typescript
// __tests__/actions/users.test.ts
import { createUserAction } from '@/app/actions/users';

describe('createUserAction', () => {
  it('creates user with valid data', async () => {
    const formData = new FormData();
    formData.append('name', 'John Doe');
    formData.append('email', 'john@example.com');

    const result = await createUserAction(formData);

    expect(result.success).toBe(true);
    expect(result.user).toMatchObject({
      name: 'John Doe',
      email: 'john@example.com',
    });
  });

  it('returns error for invalid email', async () => {
    const formData = new FormData();
    formData.append('name', 'John Doe');
    formData.append('email', 'invalid-email');

    const result = await createUserAction(formData);

    expect(result.success).toBe(false);
    expect(result.error).toBeDefined();
  });
});
```

