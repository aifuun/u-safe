## Diagnostic Export Pattern

**Use Case**: Allow users to download diagnostic reports with logs, system info, and state.

```typescript
// Service: Collect diagnostic data
export class DiagnosticService {
  async generateReport(traceId: string): Promise<DiagnosticReport> {
    logger.info({
      event: 'diagnostic:generate:start',
      traceId,
    });

    // Collect system info
    const systemInfo = {
      platform: process.platform,
      nodeVersion: process.version,
      memory: process.memoryUsage(),
    };

    // Collect recent logs (last 100 lines)
    const logs = await this.getRecentLogs(100);

    // Collect app state
    const state = await this.collectState();

    const report = {
      id: `diag-${Date.now()}`,
      timestamp: new Date().toISOString(),
      systemInfo,
      logs,
      state,
    };

    logger.info({
      event: 'diagnostic:generate:complete',
      traceId,
      reportId: report.id,
      logCount: logs.length,
    });

    return report;
  }

  private async getRecentLogs(limit: number): Promise<LogEntry[]> {
    const logFile = path.join(LOG_DIR, `${new Date().toISOString().split('T')[0]}.jsonl`);
    const content = await fs.readFile(logFile, 'utf-8');
    const lines = content.trim().split('\n');
    return lines.slice(-limit).map(line => JSON.parse(line));
  }
}
```

