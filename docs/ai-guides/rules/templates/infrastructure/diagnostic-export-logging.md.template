## TraceId Propagation Pattern

**Single traceId flows end-to-end through all layers:**

```
Client (View Layer)
  ↓ Generate traceId: crypto.randomUUID()
  ↓ Pass to Service Layer
  ↓ Service logs with traceId
  ↓ Pass to Adapter Layer
  ↓ Adapter includes traceId in HTTP headers
  ↓ Lambda extracts traceId from headers/body
  ↓ Lambda logs all events with same traceId
  ↓ Lambda includes traceId in response
  ↓ Client validates response traceId matches
```

### Implementation Example

```typescript
// View Layer: Generate traceId
function DiagnosticPanel() {
  const handleExport = async () => {
    const traceId = crypto.randomUUID();

    logger.debug({
      event: 'diagnostic:export:initiated',
      traceId,
      userId,
    });

    const result = await diagnosticService.execute({ userId, traceId });

    logger.info({
      event: 'diagnostic:export:complete',
      traceId,
      reportId: result.reportId,
    });
  };
}

// Service Layer: Propagate traceId
export class DiagnosticService {
  async execute({ userId, traceId }: { userId: string; traceId: string }) {
    logger.debug({
      event: 'diagnostic:service:start',
      traceId,
      userId,
    });

    const result = await diagnosticAdapter.export({ userId, traceId });

    return result;
  }
}

// Adapter Layer: Include traceId in request
export const diagnosticAdapter = {
  async export({ userId, traceId }: { userId: string; traceId: string }) {
    const response = await fetch(LAMBDA_URL, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Trace-Id': traceId,  // HTTP header
      },
      body: JSON.stringify({ userId, traceId }),  // Also in body
    });

    logger.debug({
      event: 'diagnostic:api:response',
      traceId,
      statusCode: response.status,
    });

    return response.json();
  },
};

// Lambda: Extract and use traceId
export const handler = async (event) => {
  const { userId, traceId } = JSON.parse(event.body);

  logger.info({
    event: 'diagnostic:lambda:start',
    traceId,
    userId,
  });

  try {
    const report = await generateReport(userId);

    logger.info({
      event: 'diagnostic:lambda:success',
      traceId,
      reportId: report.id,
      fileSize: report.size,
    });

    return {
      statusCode: 200,
      body: JSON.stringify({ ...report, traceId }),
    };
  } catch (error) {
    logger.error({
      event: 'diagnostic:lambda:error',
      traceId,
      error: error.message,
    });
    throw error;
  }
};
```

