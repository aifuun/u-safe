## Log Storage Patterns

### Local Development: JSONL Files

```typescript
// kernel/telemetry/logger.ts
import pino from 'pino';
import { createWriteStream } from 'fs';
import { mkdir } from 'fs/promises';
import path from 'path';

const LOG_DIR = path.join(process.env.HOME || '', '.myapp', 'logs');

// Ensure log directory exists
await mkdir(LOG_DIR, { recursive: true });

// Log file per day: logs/2026-02-05.jsonl
const logFile = path.join(LOG_DIR, `${new Date().toISOString().split('T')[0]}.jsonl`);

export const logger = pino(
  {
    level: process.env.LOG_LEVEL || 'info',
  },
  createWriteStream(logFile, { flags: 'a' })
);
```

### Production: CloudWatch Logs

```typescript
// CDK infrastructure
import { LogGroup, RetentionDays } from 'aws-cdk-lib/aws-logs';

new LogGroup(this, 'ApiLogs', {
  logGroupName: '/aws/lambda/api',
  retention: RetentionDays.SEVEN_DAYS,  // Dev: 7 days
  // retention: RetentionDays.THIRTY_DAYS,  // Prod: 30 days
  removalPolicy: RemovalPolicy.DESTROY,  // Dev
  // removalPolicy: RemovalPolicy.RETAIN,  // Prod
});
```

